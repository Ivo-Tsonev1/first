<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ByteBite</title>
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
</head>
<body>
    <header>
        <div class="container">
            <nav aria-label="Main navigation">
                <a asp-area="" asp-controller="Home" asp-action="Index" class="logo">ByteBite</a>

                <button class="menu-toggle" aria-label="Отваряне на меню">☰</button>

                <div class="nav-links" id="main-nav">
                    <button class="close-menu" aria-label="Затваряне на меню">✕</button>

                    <a asp-area="" asp-controller="Home" asp-action="Index">Начало</a>
                    <a asp-area="" asp-controller="Menus" asp-action="Index">Меню</a>
                    <a asp-area="" asp-controller="Home" asp-action="About">За нас</a>
                    <a asp-area="" asp-controller="Home" asp-action="Contact">Контакти</a>

                    @if (User.Identity.IsAuthenticated)
                    {
                        @if (User.IsInRole("Admin") || User.IsInRole("Waiter"))
                        {
                            <a asp-area="Waiter" asp-controller="DiningTables" asp-action="Index">Маси</a>
                            <a asp-area="Waiter" asp-controller="Orders" asp-action="Index">Поръчки</a>
                        }

                        @if (User.IsInRole("Admin"))
                        {
                            <div class="nav-item dropdown" id="adminDropdown">
                                <a class="nav-link dropdown-toggle" href="javascript:void(0)" role="button">
                                    <i class="bi bi-gear-fill"></i> Админ
                                </a>
                                <ul class="custom-dropdown-menu">
                                    <li>
                                        <a class="dropdown-item" asp-area="Admin" asp-controller="Menus" asp-action="Index">
                                            <i class="bi bi-book"></i> Управление на менюта
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-area="Admin" asp-controller="Dishes" asp-action="Index">
                                            <i class="bi bi-egg-fried"></i> Всички ястия
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-area="Admin" asp-controller="Categories" asp-action="Index">
                                            <i class="bi bi-list"></i> Категории
                                        </a>
                                    </li>
                                    <li class="divider"></li>
                                    <li>
                                        <a class="dropdown-item" asp-area="Admin" asp-controller="Roles" asp-action="Index">
                                            <i class="bi bi-shield-lock"></i> Роли и Права
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-area="Identity" asp-page="/Account/Register">
                                            <i class="bi bi-person-plus"></i> Нов служител
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-area="Admin" asp-controller="Users" asp-action="Index">
                                            <i class="bi bi-people"></i> Управление на потребители
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        }
                        <form class="logout-form" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post">
                            <button type="submit" class="logout-button">
                                <i class="bi bi-box-arrow-right"></i> Изход
                            </button>
                        </form>
                    }
                    else
                    {
                        <a class="nav-link" asp-area="Identity" asp-page="/Account/Login">
                            <i class="bi bi-box-arrow-in-right"></i> Вход
                        </a>
                    }
                </div>
            </nav>
        </div>
    </header>

    <main role="main" class="pb-3">
        @RenderBody()
    </main>

    <footer>
        <div class="container">
            <div>
                <h3>Контакти</h3>
                <p>бул. "Витоша" 88, 1000 София</p>
                <a href="tel:+359888776655">+359 888 77 66 55</a>
            </div>
            <div>
                <h3>Бързи връзки</h3>
                <a asp-area="" asp-controller="Home" asp-action="Index">Начало</a>
                <a asp-area="" asp-controller="Home" asp-action="About">За нас</a>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2026 Ресторант "ByteBite". Всички права запазени.</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/script.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>