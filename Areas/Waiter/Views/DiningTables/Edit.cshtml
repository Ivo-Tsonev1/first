@model ByteBite.Models.DiningTable

@{
    ViewData["Title"] = "Редактиране на маса";
}

<style>
    .form-container {
        background-color: #ffffff;
        padding: 2rem;
        border-radius: 8px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    .control-label {
        font-weight: 600;
        margin-bottom: 0.5rem;
        display: block;
    }
</style>

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6 form-container">
            <h2 class="mb-4">Редактиране на маса</h2>
            <hr />
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="Id" />

                <div class="form-group">
                    <label asp-for="TableNumber" class="control-label">Номер на масата</label>
                    <input asp-for="TableNumber" class="form-control" />
                    <span asp-validation-for="TableNumber" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Capacity" class="control-label">Капацитет (брой места)</label>
                    <input asp-for="Capacity" class="form-control" />
                    <span asp-validation-for="Capacity" class="text-danger"></span>
                </div>

                <div class="form-group mt-4">
                    <button type="submit" class="btn btn-primary w-100">Запази промените</button>
                </div>
            </form>

            <div class="mt-3 text-center">
                <a asp-action="Index" class="text-decoration-none text-muted">Назад към списъка</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}