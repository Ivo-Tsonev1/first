@model ByteBite.Models.Order

@{
    ViewData["Title"] = "Детайли на поръчка";
}

<style>
    /* Нашата установена топла палитра */
    :root {
        --warm-orange: #e67e22;
        --warm-orange-dark: #d35400;
        --rich-brown: #5c3a21;
        --light-tan: #fdf6f0;
        --hover-tan: #f5e3d7;
        --text-dark-brown: #3e2723;
        --text-muted-brown: #8c6b53;
        /* Меки семантични цветове за статусите */
        --soft-green-bg: #e8f5e9;
        --soft-green-text: #2e7d32;
        --soft-red-bg: #fbe9e7;
        --soft-red-text: #c62828;
    }

    .details-hero {
        background-image: linear-gradient(135deg, var(--warm-orange) 0%, var(--rich-brown) 100%);
        color: #fffdfa;
        padding: 4rem 1rem 3rem;
        margin-bottom: 3rem;
        border-radius: 12px;
        box-shadow: 0 8px 32px rgba(92, 58, 33, 0.25);
    }

        .details-hero h1 {
            font-size: 2.5rem;
            margin-bottom: 0.5rem;
            font-weight: 700;
            text-shadow: 1px 1px 3px rgba(0,0,0,0.2);
        }

        .details-hero p {
            font-size: 1.1rem;
            opacity: 0.95;
            margin: 0;
        }

    .details-container {
        max-width: 1000px;
        margin: 0 auto 3rem;
    }

    .details-card {
        background: #fffdfa;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(92, 58, 33, 0.08);
        overflow: hidden;
    }

    .card-header {
        background-image: linear-gradient(135deg, var(--warm-orange) 0%, var(--rich-brown) 100%);
        color: white;
        padding: 1.5rem 2rem;
        font-size: 1.3rem;
        font-weight: 600;
    }

    .card-body {
        padding: 2.5rem;
    }

    .info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 2rem;
        margin-bottom: 2rem;
    }

    .info-item {
        background: var(--light-tan);
        padding: 1.5rem;
        border-radius: 8px;
        border-left: 4px solid var(--warm-orange);
    }

    .info-label {
        font-size: 0.85rem;
        color: var(--text-muted-brown);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-weight: 600;
        margin-bottom: 0.5rem;
    }

    .info-value {
        font-size: 1.3rem;
        color: var(--text-dark-brown);
        font-weight: 600;
    }

    .status-badge {
        display: inline-block;
        padding: 0.6rem 1.2rem;
        border-radius: 50px;
        font-size: 0.9rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.05);
    }

    .status-paid {
        background: var(--soft-green-bg);
        color: var(--soft-green-text);
        border: 1px solid rgba(46, 125, 50, 0.2);
    }

    .status-unpaid {
        background: var(--soft-red-bg);
        color: var(--soft-red-text);
        border: 1px solid rgba(198, 40, 40, 0.2);
    }

    .price-highlight {
        background-image: linear-gradient(135deg, var(--warm-orange) 0%, var(--rich-brown) 100%);
        color: #fffdfa;
        padding: 2rem;
        border-radius: 8px;
        text-align: center;
        margin: 2rem 0;
        box-shadow: 0 4px 15px rgba(92, 58, 33, 0.15);
    }

        .price-highlight .price-label {
            font-size: 0.95rem;
            opacity: 0.9;
            margin-bottom: 0.5rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .price-highlight .price-value {
            font-size: 2.5rem;
            font-weight: 700;
            text-shadow: 1px 1px 2px rgba(0,0,0,0.2);
        }

    .actions {
        display: flex;
        gap: 1rem;
        margin-top: 2rem;
        flex-wrap: wrap;
    }

    .btn {
        padding: 0.9rem 1.8rem;
        border-radius: 8px;
        border: none;
        cursor: pointer;
        font-size: 1rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.3s ease;
    }

    .btn-primary {
        background-image: linear-gradient(135deg, var(--warm-orange) 0%, var(--warm-orange-dark) 100%);
        color: white;
    }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(211, 84, 0, 0.3);
            color: white;
        }

    .btn-secondary {
        background: var(--hover-tan);
        color: var(--rich-brown);
    }

        .btn-secondary:hover {
            background: #ebd2c1;
            transform: translateY(-2px);
            color: var(--rich-brown);
        }

    .items-section {
        margin-top: 2rem;
        padding-top: 2rem;
        border-top: 2px solid var(--light-tan);
    }

        .items-section h3 {
            color: var(--rich-brown);
            margin-bottom: 1.5rem;
            font-size: 1.3rem;
            font-weight: 700;
        }

    .item-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

        .item-list li {
            padding: 1.2rem;
            background: var(--light-tan);
            border-radius: 8px;
            margin-bottom: 0.8rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-left: 3px solid transparent;
            transition: all 0.2s ease;
        }

            .item-list li:hover {
                background: var(--hover-tan);
                border-left-color: var(--warm-orange);
            }

    .item-name {
        font-weight: 600;
        color: var(--text-dark-brown);
        font-size: 1.1rem;
    }

    .item-price {
        color: var(--warm-orange-dark);
        font-weight: 700;
        font-size: 1.1rem;
    }

    @@media (max-width: 768px) {
        .details-hero {
            padding: 2rem 1rem;
        }

            .details-hero h1 {
                font-size: 1.8rem;
            }

        .card-body {
            padding: 1.5rem;
        }

        .info-grid {
            grid-template-columns: 1fr;
            gap: 1rem;
        }

        .item-list li {
            flex-direction: column;
            align-items: flex-start;
            gap: 0.5rem;
        }

        .actions {
            flex-direction: column;
        }

        .btn {
            justify-content: center;
            flex: 1;
        }
    }
</style>

<div class="container">
    <div class="details-hero">
        <h1><i class="bi bi-receipt"></i> Поръчка #@Model.Id</h1>
        <p>Детайли и информация за поръчката</p>
    </div>

    <div class="details-container">
        <div class="details-card">
            <div class="card-header">
                <i class="bi bi-info-circle"></i> Основна информация
            </div>
            <div class="card-body">
                <div class="info-grid">
                    <div class="info-item">
                        <div class="info-label"><i class="bi bi-clock"></i> Време на поръчка</div>
                        <div class="info-value">@Model.OrderTime.ToString("dd.MM.yyyy HH:mm")</div>
                    </div>

                    <div class="info-item">
                        <div class="info-label"><i class="bi bi-table"></i> Маса</div>
                        <div class="info-value">Маса @Model.DiningTable?.Id</div>
                    </div>

                    <div class="info-item">
                        <div class="info-label"><i class="bi bi-person"></i> Сервитьор</div>
                        <div class="info-value">@(Model.Waiter?.UserName ?? "N/A")</div>
                    </div>

                    <div class="info-item">
                        <div class="info-label"><i class="bi bi-credit-card"></i> Статус на плащане</div>
                        <div class="info-value">
                            @if (Model.IsPaid)
                            {
                                <span class="status-badge status-paid">✓ Платена</span>
                            }
                            else
                            {
                                <span class="status-badge status-unpaid">⏱ Неплатена</span>
                            }
                        </div>
                    </div>
                </div>

                <div class="price-highlight">
                    <div class="price-label">Обща сума</div>
                    <div class="price-value">@Model.TotalPrice.ToString("F2") лв</div>
                </div>

                @if (Model.Items != null && Model.Items.Any())
                {
                    <div class="items-section">
                        <h3><i class="bi bi-list-ul"></i> Позиции в поръчката</h3>
                        <ul class="item-list">
                            @foreach (var item in Model.Items)
                            {
                                <li>
                                    <span class="item-name">@item.Dish?.Title</span>
                                    <span class="item-price">@item.Price.ToString("F2") лв × @item.Quantity</span>
                                </li>
                            }
                        </ul>
                    </div>
                }

                <div class="actions">
                    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-primary">
                        <i class="bi bi-pencil"></i> Редактирай
                    </a>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Назад към списък
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>