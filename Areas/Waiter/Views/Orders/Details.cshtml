@model ByteBite.Models.Order

@{
    ViewData["Title"] = "Детали на поръчка";
}

<style>
    .details-hero {
        background-image: linear-gradient(135deg, var(--accent-orange) 0%, var(--dark-accent) 100%);
        color: white;
        padding: 4rem 1rem 3rem;
        margin-bottom: 3rem;
        border-radius: 12px;
        box-shadow: 0 8px 32px rgba(102, 126, 234, 0.3);
    }

    .details-hero h1 {
        font-size: 2.5rem;
        margin-bottom: 0.5rem;
        font-weight: 700;
    }

    .details-hero p {
        font-size: 1.1rem;
        opacity: 0.95;
        margin: 0;
    }

    .details-container {
        max-width: 1000px;
        margin: 0 auto 3rem;
    }

    .details-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        overflow: hidden;
    }

    .card-header {
        background-image: linear-gradient(135deg, var(--accent-orange) 0%, var(--dark-accent) 100%);
        color: white;
        padding: 1.5rem 2rem;
        font-size: 1.3rem;
        font-weight: 600;
    }

    .card-body {
        padding: 2.5rem;
    }

    .info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 2rem;
        margin-bottom: 2rem;
    }

    .info-item {
        background: #f8f9fa;
        padding: 1.5rem;
        border-radius: 8px;
    }

    .info-label {
        font-size: 0.85rem;
        color: #666;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-weight: 600;
        margin-bottom: 0.5rem;
    }

    .info-value {
        font-size: 1.3rem;
        color: #2c3e50;
        font-weight: 600;
    }

    .status-badge {
        display: inline-block;
        padding: 0.6rem 1.2rem;
        border-radius: 50px;
        font-size: 0.9rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .status-paid {
        background: #d4edda;
        color: #155724;
    }

    .status-unpaid {
        background: #f8d7da;
        color: #721c24;
    }

    .price-highlight {
        background-image: linear-gradient(135deg, var(--accent-orange) 0%, var(--dark-accent) 100%);
        color: white;
        padding: 2rem;
        border-radius: 8px;
        text-align: center;
        margin: 2rem 0;
    }

    .price-highlight .price-label {
        font-size: 0.95rem;
        opacity: 0.9;
        margin-bottom: 0.5rem;
    }

    .price-highlight .price-value {
        font-size: 2.5rem;
        font-weight: 700;
    }

    .actions {
        display: flex;
        gap: 1rem;
        margin-top: 2rem;
        flex-wrap: wrap;
    }

    .btn {
        padding: 0.9rem 1.8rem;
        border-radius: 8px;
        border: none;
        cursor: pointer;
        font-size: 1rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.3s ease;
    }

    .btn-primary {
        background-image: linear-gradient(135deg, var(--accent-orange) 0%, var(--dark-accent) 100%);
        color: white;
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(102, 126, 234, 0.3);
    }

    .btn-secondary {
        background: #e8eaf6;
        color: #667eea;
    }

    .btn-secondary:hover {
        background: #dde3f0;
        transform: translateY(-2px);
    }

    .items-section {
        margin-top: 2rem;
        padding-top: 2rem;
        border-top: 2px solid #e8eaf6;
    }

    .items-section h3 {
        color: #2c3e50;
        margin-bottom: 1rem;
        font-size: 1.2rem;
    }

    .item-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .item-list li {
        padding: 1rem;
        background: #f8f9fa;
        border-radius: 6px;
        margin-bottom: 0.8rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .item-name {
        font-weight: 600;
        color: #2c3e50;
    }

    .item-price {
        color: #667eea;
        font-weight: 600;
    }

    @@media (max-width: 768px) {
        .details-hero {
            padding: 2rem 1rem;
        }

        .details-hero h1 {
            font-size: 1.8rem;
        }

        .card-body {
            padding: 1.5rem;
        }

        .info-grid {
            grid-template-columns: 1fr;
            gap: 1rem;
        }

        .actions {
            flex-direction: column;
        }

        .btn {
            justify-content: center;
            flex: 1;
        }
    }
</style>

<div class="container">
    <div class="details-hero">
        <h1><i class="bi bi-receipt"></i> Поръчка #@Model.Id</h1>
        <p>Детайли и информация за поръчката</p>
    </div>

    <div class="details-container">
        <div class="details-card">
            <div class="card-header">
                <i class="bi bi-info-circle"></i> Основна информация
            </div>
            <div class="card-body">
                <div class="info-grid">
                    <div class="info-item">
                        <div class="info-label"><i class="bi bi-clock"></i> Время на поръчка</div>
                        <div class="info-value">@Model.OrderTime.ToString("dd.MM.yyyy HH:mm")</div>
                    </div>

                    <div class="info-item">
                        <div class="info-label"><i class="bi bi-table"></i> Маса</div>
                        <div class="info-value">Маса @Model.DiningTable?.Id</div>
                    </div>

                    <div class="info-item">
                        <div class="info-label"><i class="bi bi-person"></i> Сервитьор</div>
                        <div class="info-value">@(Model.Waiter?.UserName ?? "N/A")</div>
                    </div>

                    <div class="info-item">
                        <div class="info-label"><i class="bi bi-credit-card"></i> Статус на плащане</div>
                        <div class="info-value">
                            @if (Model.IsPaid)
                            {
                                <span class="status-badge status-paid">✓ Платена</span>
                            }
                            else
                            {
                                <span class="status-badge status-unpaid">⏱ Неплатена</span>
                            }
                        </div>
                    </div>
                </div>

                <div class="price-highlight">
                    <div class="price-label">Обща сума</div>
                    <div class="price-value">@Model.TotalPrice.ToString("F2") лв</div>
                </div>

                @if (Model.Items != null && Model.Items.Any())
                {
                    <div class="items-section">
                        <h3><i class="bi bi-list-ul"></i> Позиции в поръчката</h3>
                        <ul class="item-list">
                            @foreach (var item in Model.Items)
                            {
                                <li>
                                    <span class="item-name">@item.Dish?.Title</span>
                                    <span class="item-price">@item.Price.ToString("F2") лв × @item.Quantity</span>
                                </li>
                            }
                        </ul>
                    </div>
                }

                <div class="actions">
                    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-primary">
                        <i class="bi bi-pencil"></i> Редактирай
                    </a>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Назад към списък
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
