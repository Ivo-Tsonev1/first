@model ByteBite.Models.Category

@{
    ViewData["Title"] = "Create Category";
    Layout = "_Layout";
}

<style>
    :root {
        --primary-brown: #2b140d;
        --accent-orange: #c2410c;
        --accent-hover: #a33a0a;
        --success-green: #10b981;
        --danger-red: #ef4444;
        --bg-light: #f8fafc;
    }

    body {
        background-color: var(--bg-light);
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
    }

    .create-header {
        background: linear-gradient(135deg, var(--primary-brown) 0%, #1a0f0a 100%);
        color: white;
        padding: 3rem 2rem;
        margin-bottom: 2.5rem;
        border-radius: 16px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
    }

    .create-header h1 {
        margin-bottom: 0.5rem;
        font-weight: 800;
        font-size: 2.5rem;
    }

    .create-header p {
        opacity: 0.9;
        font-size: 1.1rem;
    }

    .form-container {
        background: white;
        border-radius: 20px;
        padding: 3rem;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        border: 1px solid rgba(0,0,0,0.05);
        max-width: 700px;
        margin: 0 auto;
    }

    .form-group {
        margin-bottom: 2rem;
    }

    .form-group label {
        display: block;
        font-weight: 600;
        color: var(--primary-brown);
        margin-bottom: 0.75rem;
        font-size: 1rem;
    }

    .form-group input[type="text"],
    .form-group select {
        width: 100%;
        padding: 0.75rem 1rem;
        border: 2px solid #e2e8f0;
        border-radius: 10px;
        font-size: 1rem;
        font-family: inherit;
        transition: all 0.3s;
        box-sizing: border-box;
    }

    .form-group input[type="text"]:focus,
    .form-group select:focus {
        outline: none;
        border-color: var(--accent-orange);
        box-shadow: 0 0 0 3px rgba(194, 65, 12, 0.1);
    }

    .info-box {
        background: linear-gradient(135deg, rgba(194, 65, 12, 0.05) 0%, rgba(194, 65, 12, 0.02) 100%);
        border-left: 4px solid var(--accent-orange);
        padding: 1.25rem;
        border-radius: 10px;
        margin-bottom: 2rem;
    }

    .info-box p {
        margin: 0;
        color: var(--primary-brown);
        font-size: 0.95rem;
        font-weight: 500;
    }

    .info-box i {
        margin-right: 0.75rem;
        color: var(--accent-orange);
    }

    .alert-warning {
        background: #fef3c7;
        border-left: 4px solid #f59e0b;
        color: #92400e;
        padding: 1rem;
        border-radius: 8px;
        margin-bottom: 2rem;
    }

    .alert-warning i {
        margin-right: 0.75rem;
    }

    .alert-danger {
        background: #fee2e2;
        border-left: 4px solid var(--danger-red);
        color: var(--danger-red);
        padding: 1rem;
        border-radius: 8px;
        margin-bottom: 2rem;
    }

    .alert-danger i {
        margin-right: 0.75rem;
    }

    .form-section {
        padding: 1.5rem;
        background: #fafafa;
        border-radius: 12px;
        margin-bottom: 2rem;
    }

    .form-section-title {
        color: var(--primary-brown);
        font-weight: 700;
        font-size: 0.95rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
    }

    .form-section-title i {
        margin-right: 0.75rem;
        font-size: 1.2rem;
        color: var(--accent-orange);
    }

    .category-preview {
        padding: 1.5rem;
        background: white;
        border-radius: 12px;
        border: 2px dashed #e2e8f0;
        text-align: center;
        margin-top: 1rem;
        transition: all 0.3s;
    }

    .category-preview:hover {
        border-color: var(--accent-orange);
        background: #fff7ed;
    }

    .preview-text {
        color: var(--primary-brown);
        font-weight: 600;
        margin-bottom: 0.5rem;
        font-size: 0.9rem;
    }

    .preview-name {
        font-size: 1.3rem;
        color: var(--accent-orange);
        font-weight: 700;
    }

    .form-actions {
        display: flex;
        gap: 1rem;
        margin-top: 2rem;
        padding-top: 2rem;
        border-top: 2px solid #e2e8f0;
    }

    .btn-submit {
        flex: 1;
        background: linear-gradient(135deg, var(--accent-orange) 0%, var(--accent-hover) 100%);
        color: white;
        border: none;
        padding: 1rem;
        border-radius: 10px;
        font-weight: 600;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.3s;
    }

    .btn-submit:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 10px 15px rgba(194, 65, 12, 0.3);
    }

    .btn-submit:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .btn-cancel {
        flex: 1;
        background: white;
        color: var(--primary-brown);
        border: 2px solid #e2e8f0;
        padding: 1rem;
        border-radius: 10px;
        font-weight: 600;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.3s;
        text-decoration: none;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .btn-cancel:hover {
        border-color: var(--accent-orange);
        color: var(--accent-orange);
    }

    .field-error {
        color: var(--danger-red);
        font-size: 0.85rem;
        margin-top: 0.5rem;
        display: block;
    }

    .helper-text {
        color: #64748b;
        font-size: 0.85rem;
        display: block;
        margin-top: 0.5rem;
    }

    .validation-errors {
        background: #fee2e2;
        border-left: 4px solid var(--danger-red);
        color: var(--danger-red);
        padding: 1rem;
        border-radius: 8px;
        margin-bottom: 2rem;
    }

    .validation-errors ul {
        margin: 0;
        padding-left: 1.5rem;
    }

    .validation-errors li {
        margin: 0.5rem 0;
    }

    @@media (max-width: 768px) {
        .create-header {
            padding: 2rem 1rem;
        }

        .form-container {
            padding: 1.5rem;
        }

        .form-actions {
            flex-direction: column;
        }
    }
</style>

<div class="create-header">
    <h1><i class="bi bi-plus-circle me-2"></i>Create New Category</h1>
    <p>Organize your menu with a new food category</p>
</div>

<div class="container">
    <div class="form-container">
        <div class="info-box">
            <p><i class="bi bi-lightbulb"></i> Categories organize your menu items (e.g., Appetizers, Main Courses, Desserts, Beverages)</p>
        </div>

        @if (ViewBag.WarningMessage != null)
        {
            <div class="alert-warning">
                <i class="bi bi-exclamation-triangle"></i>
                <strong>Warning:</strong> @ViewBag.WarningMessage
            </div>
        }

        @if (ViewBag.ErrorMessage != null)
        {
            <div class="alert-danger">
                <i class="bi bi-exclamation-circle"></i>
                <strong>Error:</strong> @ViewBag.ErrorMessage
            </div>
        }

        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Count > 0)
        {
            <div class="validation-errors">
                <strong>Please fix the following errors:</strong>
                <ul>
                    @foreach (var modelState in ViewData.ModelState.Values)
                    {
                        @foreach (var error in modelState.Errors)
                        {
                            <li>@error.ErrorMessage</li>
                        }
                    }
                </ul>
            </div>
        }

        <form asp-action="Create" asp-controller="Categories" method="post">
            <div class="form-section">
                <div class="form-section-title">
                    <i class="bi bi-tag"></i> Category Details
                </div>

                <div class="form-group">
                    <label asp-for="Name">Category Name <span style="color: var(--danger-red);">*</span></label>
                    <input type="text" asp-for="Name" placeholder="e.g., Appetizers, Main Courses, Desserts..." class="form-control" required />
                    <span asp-validation-for="Name" class="field-error"></span>
                    <span class="helper-text"><i class="bi bi-info-circle"></i> Enter a descriptive name</span>
                </div>

                <div class="form-group">
                    <label asp-for="MenuId">Assign to Menu <span style="color: var(--danger-red);">*</span></label>
                    <select asp-for="MenuId" asp-items="@(ViewData["MenuId"] as SelectList)" class="form-control" required>
                        <option value="">-- Select a Menu --</option>
                    </select>
                    <span asp-validation-for="MenuId" class="field-error"></span>
                    <span class="helper-text"><i class="bi bi-info-circle"></i> Choose which menu this belongs to</span>
                </div>
            </div>

            <div class="form-section">
                <div class="form-section-title">
                    <i class="bi bi-palette"></i> Category Preview
                </div>
                
                <div class="category-preview">
                    <div style="font-size: 2.5rem; margin-bottom: 1rem;">🏷️</div>
                    <div class="preview-text">Your category will appear as:</div>
                    <div class="preview-name" id="previewName">New Category</div>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-submit">
                    <i class="bi bi-check-circle me-2"></i>Create Category
                </button>
                <a asp-action="Index" asp-controller="Categories" class="btn-cancel">
                    <i class="bi bi-arrow-left me-2"></i>Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        // Live preview
        const nameInput = document.querySelector('input[name="Name"]');
        const previewName = document.getElementById('previewName');

        if (nameInput && previewName) {
            nameInput.addEventListener('input', function() {
                previewName.textContent = this.value.trim() || 'New Category';
            });
            
            if (nameInput.value) {
                previewName.textContent = nameInput.value;
            }
        }
    </script>
}
