@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Identity
@model IEnumerable<IdentityUser>

@{
    ViewData["Title"] = "Управление на потребители";
}

<div class="page-wrapper">
    <div class="page-header">
        <div class="container">
            <div class="header-content">
                <h1><i class="bi bi-people-fill"></i> Потребители</h1>
            </div>
        </div>
    </div>

    <div class="container content-wrapper">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <i class="bi bi-inbox"></i>
                <h2>Няма потребители</h2>
                <p>Потребителите ще се появят тук</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th><i class="bi bi-envelope"></i> Имейл / Потребител</th>
                            <th>Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td>
                                    <span class="category-name">@user.Email</span>
                                </td>
                                <td>
                                    <div class="action-buttons">
                                        <form asp-action="AssignAdmin" asp-route-userId="@user.Id" method="post" style="display:inline;">
                                            <button type="submit" class="btn-icon" title="Направи админ">
                                                <i class="bi bi-shield-lock"></i>
                                            </button>
                                        </form>

                                        <form asp-action="AssignWaiter" asp-route-userId="@user.Id" method="post" style="display:inline;">
                                            <button type="submit" class="btn-icon" title="Направи келнер">
                                                <i class="bi bi-person-badge"></i>
                                            </button>
                                        </form>

                                        <form asp-action="DeleteUser" asp-route-userId="@user.Id" method="post" style="display:inline;"
                                              onsubmit="return confirm('Сигурни ли сте, че искате да изтриете този потребител?');">
                                            <button type="submit" class="btn-icon btn-icon-danger" title="Изтрий">
                                                <i class="bi bi-trash-fill"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>