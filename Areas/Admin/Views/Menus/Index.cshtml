@model IEnumerable<ByteBite.Models.Menu>

@{
    ViewData["Title"] = "Менюта";
}

<div class="page-wrapper">
    <div class="page-header">
        <div class="container">
            <div class="header-content">
                <h1><i class="bi bi-book"></i> Менюта</h1>
                <a asp-action="Create" class="btn btn-primary">
                    <i class="bi bi-plus-lg"></i> Ново меню
                </a>
            </div>
        </div>
    </div>

    <div class="container content-wrapper">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <i class="bi bi-inbox"></i>
                <h2>Няма менюта</h2>
                <p>Начните с добавяне на ново меню</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th><i class="bi bi-book-fill"></i> Име на меню</th>
                            <th>Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <span class="category-name">@Html.DisplayFor(modelItem => item.Name)</span>
                                </td>
                                <td>
                                    <div class="action-buttons">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn-icon" title="Редактирай">
                                            <i class="bi bi-pencil-fill"></i>
                                        </a>
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn-icon" title="Детали">
                                            <i class="bi bi-eye-fill"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn-icon btn-icon-danger" title="Изтрий">
                                            <i class="bi bi-trash-fill"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
